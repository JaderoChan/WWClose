#include <windows.h>

#cmakedefine PROJECT_VERSION_TWEAK

#ifdef PROJECT_VERSION_TWEAK
    #define FILEVERSION_DEF @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@PROJECT_VERSION_TWEAK@
#else
    #define FILEVERSION_DEF @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@
#endif

#define PRODUCTVERSION_DEF @APP_VERSION_MAJOR@,@APP_VERSION_MINOR@,@APP_VERSION_PATCH@

#define FILEVERSION_STR "@PROJECT_VERSION@\0"
#define PRODUCTVERSION_STR "@APP_VERSION@\0"

APP_ICON ICON "@APP_ICON@"

1 VERSIONINFO
FILEVERSION FILEVERSION_DEF
PRODUCTVERSION PRODUCTVERSION_DEF
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "@APP_ORGANIZATION@\0"
      VALUE "ProductName", "@APP_TITLE@\0"
      VALUE "ProductVersion", PRODUCTVERSION_STR
      VALUE "FileVersion", FILEVERSION_STR
      VALUE "FileDescription", "@APP_TITLE@\0"
      VALUE "LegalCopyright", "@APP_COPYRIGHT_TEXT@\0"
      VALUE "Contact e-mail", "@APP_CONTACT_EMAIL@\0"
    END

  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
